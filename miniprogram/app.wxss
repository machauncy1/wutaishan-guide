/**app.wxss**/
page {
  background: #F7F3EE;
  margin: 0;
  padding: 0;
  font-family: PingFang SC, -apple-system, BlinkMacSystemFont, sans-serif;
  -webkit-overflow-scrolling: touch;
}

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}
