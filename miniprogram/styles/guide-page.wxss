/* 攻略页共享样式 (ticketGuide / trafficGuide / blessingGuide) */

page {
  background: #F2F4F7;
  margin: 0;
  padding: 0;
}

.page {
  min-height: 100vh;
  padding-bottom: 176rpx;
  box-sizing: border-box;
}

/* ===== 页面 Banner（图片通顶，导航栏嵌入内部） ===== */
.page-banner {
  position: relative;
  overflow: hidden;
  /* 兜底渐变：与首页一致 */
  background:
    radial-gradient(ellipse at 70% 35%, rgba(210, 140, 80, 0.5) 0%, transparent 50%),
    linear-gradient(175deg, #6B5A7A 0%, #8B6A5C 35%, #C08A60 65%, #3D4A2E 100%);
}

.page-banner-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.6s ease;
}

.page-banner-img-loaded {
  opacity: 1;
}

.page-banner-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.08) 0%,
    rgba(0, 0, 0, 0.12) 26%,
    rgba(0, 0, 0, 0.46) 100%
  );
}

.page-banner-content {
  position: relative;
  z-index: 1;
  padding: 0 24rpx 48rpx;
}

/* 导航栏（嵌入 banner 内部） */
.page-banner-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back,
.nav-placeholder {
  width: 88rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.nav-back { justify-content: flex-start; }
.nav-placeholder { justify-content: flex-end; }

.nav-back-icon {
  font-size: 56rpx;
  line-height: 1;
  color: #FFFFFF;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
  margin-top: 16rpx;
}

.banner-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* ===== 通用区块 ===== */
.section {
  margin: 18rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* ===== FAQ 列表 ===== */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.faq-item {
  border-bottom: 1rpx solid #F0F1F3;
  padding: 20rpx 0;
}

.faq-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.faq-item:first-child {
  padding-top: 0;
}

.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.faq-q-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.4;
}

.faq-arrow {
  font-size: 36rpx;
  color: #C0C4CC;
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
}

.faq-a {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.faq-a text {
  font-size: 26rpx;
  color: #4A4A4A;
  line-height: 1.7;
}

/* ===== 建议列表 ===== */
.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tip-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #2577E3;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.75;
  color: #4A4A4A;
}

/* ===== 导游引导区 ===== */
.guide-cta-section {
  margin: 18rpx 24rpx 0;
  background: linear-gradient(135deg, #F5F0EB 0%, #EDE7E0 100%);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.guide-cta-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.guide-cta-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* ===== 页面底部描述 ===== */
.page-footer-desc {
  padding: 12rpx 24rpx;
  font-size: 16rpx;
  color: #DCDFE3;
  line-height: 1.5;
}
