{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "lib": ["ES2018"],
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["miniprogram-api-typings"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "miniprogram_npm"]
}
