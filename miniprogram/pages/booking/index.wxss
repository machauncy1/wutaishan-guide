page {
  background: #F2F4F7;
  margin: 0;
  padding: 0;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== 导航栏 ===== */

.nav-bar {
  /* 取自详情页 hero 渐变的主色调，窄区域用简单线性渐变 */
  background: linear-gradient(90deg, #6B5A7A 0%, #8B6A5C 100%);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back,
.nav-placeholder {
  width: 88rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.nav-back {
  justify-content: flex-start;
}

.nav-placeholder {
  justify-content: flex-end;
}

.nav-back-icon {
  font-size: 56rpx;
  line-height: 1;
  color: #FFFFFF;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 表单 ===== */

.form {
  margin: 12rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.field {
  padding: 16rpx 0;
}

.field-label {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}

.field-required {
  color: #E74C3C;
  font-size: 28rpx;
}

.field-optional {
  font-size: 20rpx;
  color: #A3AAB5;
  font-weight: 400;
  background: #F2F4F7;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 4rpx;
}

.field-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  background: #F7F8FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.field-error .field-input,
.field-error .field-textarea {
  border-color: #E74C3C;
}

.field-error-text {
  display: block;
  font-size: 22rpx;
  color: #E74C3C;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* ===== 日期选择器 ===== */

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  background: #F7F8FA;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.picker-placeholder {
  color: #C0C4CC;
}

.picker-arrow {
  font-size: 36rpx;
  color: #C0C4CC;
}

/* ===== 时段单选 ===== */

.radio-group {
  display: flex;
  gap: 16rpx;
}

.radio-pill {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #4A4A4A;
  background: #F7F8FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.radio-pill-active {
  color: #2577E3;
  background: #EBF5FB;
  border-color: #2577E3;
  font-weight: 600;
}

/* ===== 人数步进器 ===== */

.stepper {
  display: flex;
  align-items: center;
  gap: 0;
  width: fit-content;
}

.stepper-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  background: #F7F8FA;
  border-radius: 12rpx;
}

.stepper-btn:active {
  background: #E8EAED;
}

.stepper-btn-disabled {
  color: #D0D3D8;
}

.stepper-btn-disabled:active {
  background: #F7F8FA;
}

.stepper-value {
  width: 96rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.stepper-unit {
  font-size: 26rpx;
  color: #A3AAB5;
  margin-left: 8rpx;
}

/* ===== 信任背书 ===== */

.trust-bar {
  margin: 16rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #4A4A4A;
}

.trust-check {
  font-size: 22rpx;
  color: #34C759;
  font-weight: 700;
}

/* ===== 备注 ===== */

.field-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  background: #F7F8FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.textarea-count {
  text-align: right;
  font-size: 20rpx;
  color: #C0C4CC;
  margin-top: 8rpx;
}

/* ===== 提交按钮 ===== */

.submit-wrap {
  padding: 20rpx 24rpx 0;
}

.submit-btn {
  width: 100% !important;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: linear-gradient(90deg, #00A7FA 0%, #0076F5 100%);
  border-radius: 20rpx;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(0, 134, 246, 0.30);
  letter-spacing: 2rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  opacity: 0.92;
}

.submit-btn-loading {
  opacity: 0.7;
}

/* ===== 手机号提示 ===== */

.field-hint {
  font-size: 22rpx;
  color: #A3AAB5;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* ===== 协议勾选 ===== */

.agreement-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.agreement-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #C0C4CC;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.agreement-checkbox-checked {
  background: #2577E3;
  border-color: #2577E3;
}

.agreement-check-icon {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.agreement-link {
  color: #2577E3;
}
