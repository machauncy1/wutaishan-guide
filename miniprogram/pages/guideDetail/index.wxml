<!--pages/guideDetail/index.wxml-->
<view class="page">

  <view class="hero">
    <image
      class="hero-img"
      src="{{settings.bannerImage}}"
      mode="aspectFill"
    />
    <view class="hero-gradient"></view>

    <view class="hero-inner">
      <view style="height: {{statusBarHeight}}px"></view>

      <view class="hero-nav" style="height: {{navBarHeight}}px">
        <view class="nav-back" bindtap="onBack">
          <text class="nav-back-icon">‹</text>
        </view>
        <view class="nav-title">导游详情</view>
        <view class="nav-placeholder"></view>
      </view>

      <block wx:if="{{guide}}">
        <view class="hero-main">
          <view class="hero-name">{{guide.name}}</view>
          <view class="hero-subtitle">{{heroSubtitle || (guide.licenseText || '本地持证导游')}}</view>
          <view class="hero-badges">
            <view class="hero-badge">
              <image class="badge-img" src="/images/icons/check-blue.svg" />
              <text>正规持证服务</text>
            </view>
            <view class="hero-badge">
              <image class="badge-img" src="/images/icons/pin-red.svg" />
              <text>熟悉五台山路线</text>
            </view>
          </view>
        </view>
      </block>

      <view wx:elif="{{loading}}" class="hero-skeleton">
        <view class="sk-hero-line sk-hero-short"></view>
        <view class="sk-hero-line sk-hero-title"></view>
        <view class="sk-hero-line sk-hero-mid"></view>
      </view>
    </view>
  </view>

  <!-- SEO 静态兜底：爬虫抓取时 guide 为空，此区域可见；数据加载后隐藏 -->
  <view class="seo-fallback" wx:if="{{!guide && !loading}}">
    <view class="seo-fallback-inner">
      <view class="seo-title">五台山导游讲解服务</view>
      <view class="seo-text">五台山导游讲解服务，支持五台山一日游、五台山深度游路线安排。提供五台山接站、五台山包车、五台山接送站服务。适合五台山自由行游客、首次来五台山游客，可根据需求定制行程。五台山导游多少钱？根据人数、时间和行程不同，一般为定制报价。首次来五台山或想深入了解文化的游客更推荐请导游讲解。</view>
    </view>
  </view>

  <view class="content-sheet">
    <view wx:if="{{loading}}" class="skeleton-wrap">
      <view class="sk-profile-card">
        <view class="sk-avatar"></view>
        <view class="sk-info">
          <view class="sk-line sk-short"></view>
          <view class="sk-line sk-mid"></view>
          <view class="sk-line sk-long"></view>
        </view>
      </view>
      <view class="sk-block"></view>
      <view class="sk-block sk-block-sm"></view>
    </view>

    <block wx:elif="{{guide}}">

      <view class="summary-strip">
        <view class="summary-avatar-wrap">
          <image
            wx:if="{{guide.avatar}}"
            class="summary-avatar {{avatarLoaded ? 'summary-avatar-loaded' : ''}}"
            src="{{guide.avatar}}"
            mode="aspectFill"
            bindload="onAvatarLoad"
          />
          <view wx:else class="summary-avatar summary-avatar-fallback">
            <text class="summary-avatar-char">{{guide.name[0] || ''}}</text>
          </view>
        </view>

        <view class="summary-metrics">
          <view class="summary-item" wx:for="{{trustPoints || []}}" wx:key="label">
            <view class="summary-label">{{item.label}}</view>
            <view class="summary-value">{{item.value}}</view>
          </view>
        </view>
      </view>

      <view class="section" wx:if="{{serviceScope.length}}">
        <view class="section-head">
          <view class="section-title">服务说明</view>
        </view>
        <view class="bullet-list">
          <view class="bullet-item" wx:for="{{serviceScope || []}}" wx:key="*this">
            <text class="bullet-dot"></text>
            <text class="bullet-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="section" wx:if="{{bookingArrangement.length}}">
        <view class="section-head">
          <view class="section-title">预订与安排</view>
        </view>
        <view class="bullet-list">
          <view class="bullet-item" wx:for="{{bookingArrangement || []}}" wx:key="*this">
            <text class="bullet-dot"></text>
            <text class="bullet-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="section faq-section" wx:if="{{faq.length}}">
        <view class="section-head">
          <view class="section-title">常见问题</view>
        </view>
        <view class="faq-list">
          <view class="faq-item" wx:for="{{faq}}" wx:key="q">
            <view class="faq-q">{{item.q}}</view>
            <view class="faq-a">{{item.a}}</view>
          </view>
        </view>
      </view>

      <view class="section reviews-section" wx:if="{{reviewTotal}}">
        <view class="section-head">
          <view class="section-title">游客评价</view>
          <view class="review-summary">
            <text class="review-score">{{reviewScore}}</text>
            <text class="review-count">（{{reviewTotal}}条评价）</text>
          </view>
        </view>

        <view class="review-list">
          <view class="review-item" wx:for="{{reviewList || []}}" wx:key="index">
            <view class="review-avatar">
              <text class="review-avatar-char">{{item.nickname[0]}}</text>
            </view>
            <view class="review-body">
              <view class="review-top">
                <text class="review-nickname">{{item.nickname}}</text>
                <view class="review-stars">
                  <text class="star" wx:for="{{item.stars || []}}" wx:for-item="star" wx:key="index">{{star}}</text>
                </view>
              </view>
              <view class="review-bottom">
                <text class="review-trip-type">{{item.tripType}}</text>
                <text class="review-date">{{item.date}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="review-more" wx:if="{{reviewTotal > 3}}" bindtap="onToggleReviews">
          <text>{{showAllReviews ? '收起评价' : '查看全部' + reviewTotal + '条评价'}}</text>
        </view>
      </view>
    </block>
  </view>

</view>

<bottom-contact-bar
  wx:if="{{guide && settings.contactPhone}}"
  phone="{{settings.contactPhone}}"
  show-consult="{{guide.wechatServiceEnabled}}"
  show-booking="{{true}}"
  consult-label="咨询行程"
  phone-label="电话沟通"
  bindbooking="onBooking"
  bindconsult="onConsult"
/>

<!-- 微信客服浮层 -->
<view wx:if="{{showContactOverlay}}" class="contact-overlay" bindtap="onCloseOverlay">
  <view class="contact-sheet" catchtap="">
    <view class="contact-sheet-title">微信在线咨询</view>
    <view class="contact-sheet-desc">点击下方按钮进入客服会话</view>
    <button
      class="contact-sheet-btn"
      open-type="contact"
      bindcontact="onContactSuccess"
      hover-class="contact-sheet-btn-hover"
    >开始咨询</button>
    <view class="contact-sheet-cancel" bindtap="onCloseOverlay">取消</view>
  </view>
</view>
