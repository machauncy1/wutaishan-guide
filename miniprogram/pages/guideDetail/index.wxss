page {
  background: #F2F4F7;
  margin: 0;
  padding: 0;
  overflow-x: hidden;
}

.page {
  min-height: 100vh;
  padding-bottom: 72rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.hero {
  position: relative;
  overflow: hidden;
  /* 兜底渐变：暖色晚霞山景 */
  background:
    radial-gradient(ellipse at 70% 35%, rgba(210, 140, 80, 0.5) 0%, transparent 50%),
    linear-gradient(175deg, #6B5A7A 0%, #8B6A5C 35%, #C08A60 65%, #3D4A2E 100%);
}

.hero-img,
.hero-gradient {
  position: absolute;
  inset: 0;
}

.hero-img {
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.6s ease;
}

.hero-img-loaded {
  opacity: 1;
}

.hero-gradient {
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.08) 0%,
    rgba(0, 0, 0, 0.12) 26%,
    rgba(0, 0, 0, 0.46) 100%
  );
}

.hero-inner {
  position: relative;
  z-index: 1;
  padding: 0 24rpx 68rpx;
}

.hero-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back,
.nav-placeholder {
  width: 88rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.nav-back {
  justify-content: flex-start;
}

.nav-placeholder {
  justify-content: flex-end;
}

.nav-back-icon {
  font-size: 56rpx;
  line-height: 1;
  color: #FFFFFF;
}

.nav-title {
  flex: 1;
  text-align: center;
  padding: 0 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-main {
  padding: 18rpx 8rpx 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hero-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.35);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 1rpx;
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
}

.hero-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 100rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.94);
}

.hero-badge text:last-child {
  max-width: 290rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge-icon {
  font-size: 22rpx;
}

.badge-icon-check {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  background: #3B8BF2;
  border-radius: 50%;
  font-size: 18rpx;
  color: #FFFFFF;
}

.hero-skeleton {
  padding: 24rpx 8rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sk-hero-line {
  height: 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.3);
  animation: pulse 1.4s ease infinite;
}

.sk-hero-short { width: 28%; }
.sk-hero-title { width: 52%; height: 56rpx; }
.sk-hero-mid { width: 44%; }

.content-sheet {
  position: relative;
  z-index: 2;
  margin-top: -28rpx;
  background: #F2F4F7;
  border-radius: 28rpx 28rpx 0 0;
  padding-top: 24rpx;
}

.summary-strip,
.section,
.sk-profile-card,
.sk-block {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.summary-strip {
  margin: 0 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 36rpx;
}

.summary-avatar-wrap {
  flex-shrink: 0;
  padding-left: 4rpx;
}

.summary-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 16rpx;
  display: block;
}

.summary-avatar-fallback {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-avatar-char {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.summary-metrics {
  width: 320rpx;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  justify-content: center;
}

.summary-item {
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.summary-label {
  font-size: 20rpx;
  color: #A3AAB5;
  width: 84rpx;
  flex-shrink: 0;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #1A1A1A;
  letter-spacing: 0.5rpx;
}

.summary-note {
  font-size: 24rpx;
  color: #2577E3;
}

.section {
  margin: 18rpx 24rpx 0;
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #2E86C1;
  background: #EBF5FB;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  line-height: 1.3;
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.85;
  color: #4A4A4A;
}

.service-desc {
  margin-top: 16rpx;
}

.bullet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.bullet-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #2577E3;
  flex-shrink: 0;
}

.bullet-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.75;
  color: #4A4A4A;
}

.skeleton-wrap {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.sk-profile-card {
  padding: 28rpx 24rpx;
  display: flex;
  gap: 20rpx;
}

.sk-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #E8EAED;
  flex-shrink: 0;
  animation: pulse 1.4s ease infinite;
}

.sk-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.sk-line {
  height: 24rpx;
  border-radius: 4rpx;
  background: #E8EAED;
  animation: pulse 1.4s ease infinite;
}

.sk-short { width: 36%; }
.sk-mid { width: 62%; }
.sk-long { width: 84%; }

.sk-block {
  height: 180rpx;
  animation: pulse 1.4s ease infinite;
}

.sk-block-sm {
  height: 120rpx;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.45; }
}
