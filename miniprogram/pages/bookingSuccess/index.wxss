page {
  background: #F2F4F7;
  margin: 0;
  padding: 0;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* ===== 主内容 ===== */

.main {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-circle {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #34C759 0%, #30B350 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.3);
}

.icon-check {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.title {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #A3AAB5;
}

/* ===== 预约摘要 ===== */

.summary {
  width: 100%;
  margin-top: 36rpx;
  padding: 24rpx 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-header {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A1A;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F1F3;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-label {
  font-size: 24rpx;
  color: #A3AAB5;
}

.summary-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* ===== 联系提示 ===== */

.contact-tip {
  width: 100%;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #FFF8EE;
  border-radius: 12rpx;
  box-sizing: border-box;
  text-align: center;
}

.contact-tip-text {
  font-size: 24rpx;
  color: #D4930A;
  font-weight: 500;
  display: block;
}


/* ===== 立即沟通 ===== */

.call-btn {
  width: 100%;
  margin-top: 28rpx;
  padding: 24rpx 0;
  background: linear-gradient(90deg, #00A7FA 0%, #0076F5 100%);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 134, 246, 0.25);
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  box-sizing: border-box;
}

.call-btn-hover {
  opacity: 0.88;
}

/* ===== 信任背书 ===== */

.trust {
  width: 100%;
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.trust-item {
  font-size: 22rpx;
  color: #A3AAB5;
}

/* ===== 底部操作 ===== */

.actions {
  width: 100%;
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.btn-primary {
  width: 100% !important;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #4A4A4A;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #E8EAED;
  box-shadow: none;
}

.btn-primary::after {
  border: none;
}

.btn-text {
  font-size: 24rpx;
  color: #A3AAB5;
  padding: 8rpx 0;
}

.btn-hover {
  opacity: 0.85;
}
