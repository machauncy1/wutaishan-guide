<!--pages/index/index.wxml-->
<view class="page">

  <!-- ===== Banner ===== -->
  <view class="banner">
    <image
      class="banner-img {{bannerLoaded ? 'banner-img-loaded' : ''}}"
      src="{{settings.bannerImage}}"
      mode="aspectFill"
      bindload="onBannerLoad"
    />
    <view class="banner-gradient"></view>

    <view class="banner-inner">
      <!-- 状态栏占位 -->
      <view style="height: {{statusBarHeight}}px"></view>
      <!-- 导航栏占位 -->
      <view style="height: {{navBarHeight}}px"></view>

      <!-- 主标题区 -->
      <view class="banner-main">
        <view class="banner-title">五台山导游服务</view>
        <view class="banner-subtitle">专业讲解 · 路线规划 · 门票约车指南</view>
        <view class="banner-badges">
          <view class="banner-badge">
            <image class="badge-img" src="/images/icons/check-blue.svg" />
            <text>正规持证导游</text>
          </view>
          <view class="banner-badge">
            <image class="badge-img" src="/images/icons/pin-red.svg" />
            <text>五台山景区</text>
          </view>
          <view class="banner-badge">
            <image class="badge-img" src="/images/icons/star-yellow.svg" />
            <text>已服务{{settings.serviceTotal || '21300'}}+游客</text>
          </view>
        </view>
      </view>
    </view>

  </view>

  <!-- ===== 内容区 ===== -->
  <view class="content-sheet">

    <!-- ===== 核心入口区（横向滑动） ===== -->
    <view class="entry-scroll-wrap">
      <scroll-view class="entry-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="entry-track">
          <view class="entry-chip" bindtap="onEntryTap" data-path="/pages/ticketGuide/index">
            <image class="entry-chip-icon" src="cloud://cloud1-7g44gn8c3a08ced5.636c-cloud1-7g44gn8c3a08ced5-1411386376/ticket.webp" />
            <text class="entry-chip-text">门票怎么买</text>
            <view class="entry-chip-arrow">
              <mp-icon icon="arrow" color="#C0C4CC" size="{{12}}"></mp-icon>
            </view>
          </view>
          <view class="entry-chip" bindtap="onEntryTap" data-path="/pages/trafficGuide/index">
            <image class="entry-chip-icon" src="cloud://cloud1-7g44gn8c3a08ced5.636c-cloud1-7g44gn8c3a08ced5-1411386376/traffic.webp" />
            <text class="entry-chip-text">交通怎么走</text>
            <view class="entry-chip-arrow">
              <mp-icon icon="arrow" color="#C0C4CC" size="{{12}}"></mp-icon>
            </view>
          </view>
          <view class="entry-chip" bindtap="onEntryTap" data-path="/pages/blessingGuide/index">
            <image class="entry-chip-icon" src="cloud://cloud1-7g44gn8c3a08ced5.636c-cloud1-7g44gn8c3a08ced5-1411386376/route.webp" />
            <text class="entry-chip-text">行程怎么安排</text>
            <view class="entry-chip-arrow">
              <mp-icon icon="arrow" color="#C0C4CC" size="{{12}}"></mp-icon>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="entry-scroll-fade"></view>
    </view>

    <!-- 导游列表 -->
    <view class="section-header">
      <text class="section-title">本地持证导游</text>
      <view class="section-cert-badge">
        <image class="section-cert-icon" src="/images/icons/gov-blue.svg" />
        <text class="section-cert-text">五台山官方平台认证可查</text>
      </view>
    </view>
    <view class="guide-section">
      <view class="list-wrap">

        <view wx:if="{{loading}}" class="skeleton-list">
          <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
            <view class="sk-avatar"></view>
            <view class="sk-info">
              <view class="sk-line sk-short"></view>
              <view class="sk-line sk-mid"></view>
              <view class="sk-line sk-long"></view>
            </view>
          </view>
        </view>

        <view wx:else>
          <view
            wx:for="{{guideList || []}}"
            wx:key="_id"
            class="card-wrap"
            bindtap="onGuideTap"
            data-id="{{item._id}}"
          >
            <guide-card guide="{{item}}" />
          </view>

          <view wx:if="{{!guideList.length}}" class="empty">
            <text class="empty-icon">🏔</text>
            <text class="empty-text">暂无导游信息</text>
          </view>
        </view>

      </view>
    </view>

    <!-- 协议入口 -->
    <view class="footer-links">
      <text class="footer-link" bindtap="goAgreement">用户服务协议</text>
      <text class="footer-divider">|</text>
      <text class="footer-link" bindtap="goPrivacy">隐私政策</text>
    </view>

  </view>
</view>

<bottom-contact-bar
  wx:if="{{settings.contactPhone}}"
  phone="{{settings.contactPhone}}"
  show-consult="{{settings.wechatServiceEnabled}}"
  consult-label="咨询行程"
  phone-label="电话沟通"
/>
