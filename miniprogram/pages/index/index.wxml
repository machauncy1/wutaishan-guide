<!--pages/index/index.wxml-->
<view class="page">

  <!-- ===== Banner ===== -->
  <view class="banner">
    <image
      class="banner-img {{bannerLoaded ? 'banner-img-loaded' : ''}}"
      src="{{settings.bannerImage}}"
      mode="aspectFill"
      bindload="onBannerLoad"
    />
    <view class="banner-gradient"></view>

    <view class="banner-inner">
      <!-- 状态栏占位 -->
      <view style="height: {{statusBarHeight}}px"></view>
      <!-- 导航栏占位 -->
      <view style="height: {{navBarHeight}}px"></view>

      <!-- 主标题区 -->
      <view class="banner-main">
        <view class="banner-title">五台山导游服务</view>
        <view class="banner-subtitle">新世纪之旅 · 专业讲解 · 路线规划 · 门票约车指南</view>
        <view class="banner-badges">
          <view class="banner-badge">
            <text class="badge-icon badge-icon-check">✓</text>
            <text>正规持证导游</text>
          </view>
          <view class="banner-badge">
            <text class="badge-icon">📍</text>
            <text>五台山景区</text>
          </view>
          <view class="banner-badge">
            <text class="badge-icon">⭐</text>
            <text>已服务{{settings.serviceTotal || '21300'}}+游客</text>
          </view>
        </view>
      </view>
    </view>

  </view>

  <!-- ===== 内容区 ===== -->
  <view class="content-sheet">

    <!-- ===== 核心入口区 ===== -->
    <view class="entry-section">
      <view class="entry-card" bindtap="onEntryTap" data-path="/pages/ticketGuide/index">
        <view class="entry-icon entry-icon-ticket">
          <image class="entry-icon-img" src="cloud://cloud1-7g44gn8c3a08ced5.636c-cloud1-7g44gn8c3a08ced5-1411386376/ticket.webp" />
        </view>
        <view class="entry-info">
          <text class="entry-title">五台山门票怎么买</text>
          <text class="entry-sub">是否限流 / 提前几天 / 当天能不能进</text>
        </view>
        <view class="entry-arrow">
          <mp-icon icon="arrow" color="#C0C4CC" size="{{16}}"></mp-icon>
        </view>
      </view>
      <view class="entry-card" bindtap="onEntryTap" data-path="/pages/trafficGuide/index">
        <view class="entry-icon entry-icon-traffic">
          <image class="entry-icon-img" src="cloud://cloud1-7g44gn8c3a08ced5.636c-cloud1-7g44gn8c3a08ced5-1411386376/traffic.webp" />
        </view>
        <view class="entry-info">
          <text class="entry-title">五台山交通怎么走</text>
          <text class="entry-sub">打车约车 / 公交方便吗 / 拥堵情况</text>
        </view>
        <view class="entry-arrow">
          <mp-icon icon="arrow" color="#C0C4CC" size="{{16}}"></mp-icon>
        </view>
      </view>
      <view class="entry-card" bindtap="onEntryTap" data-path="/pages/blessingGuide/index">
        <view class="entry-icon entry-icon-trip">
          <image class="entry-icon-img" src="cloud://cloud1-7g44gn8c3a08ced5.636c-cloud1-7g44gn8c3a08ced5-1411386376/route.webp" />
        </view>
        <view class="entry-info">
          <text class="entry-title">五台山行程怎么安排</text>
          <text class="entry-sub">文化讲解 / 景点参观 / 省心安排</text>
        </view>
        <view class="entry-arrow">
          <mp-icon icon="arrow" color="#C0C4CC" size="{{16}}"></mp-icon>
        </view>
      </view>
    </view>

    <!-- 导游列表 -->
    <view class="guide-section">
      <view class="section-header">
        <text class="section-title">本地持证导游</text>
      </view>
      <view class="list-wrap">

        <view wx:if="{{loading}}" class="skeleton-list">
          <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
            <view class="sk-avatar"></view>
            <view class="sk-info">
              <view class="sk-line sk-short"></view>
              <view class="sk-line sk-mid"></view>
              <view class="sk-line sk-long"></view>
            </view>
          </view>
        </view>

        <view wx:else>
          <view
            wx:for="{{guideList || []}}"
            wx:key="_id"
            class="card-wrap"
            bindtap="onGuideTap"
            data-id="{{item._id}}"
          >
            <guide-card guide="{{item}}" />
          </view>

          <view wx:if="{{!guideList.length}}" class="empty">
            <text class="empty-icon">🏔</text>
            <text class="empty-text">暂无导游信息</text>
          </view>
        </view>

      </view>
    </view>

    <!-- 协议入口 -->
    <view class="footer-links">
      <text class="footer-link" bindtap="goAgreement">用户服务协议</text>
      <text class="footer-divider">|</text>
      <text class="footer-link" bindtap="goPrivacy">隐私政策</text>
    </view>

  </view>
</view>

<bottom-contact-bar
  wx:if="{{settings.contactPhone}}"
  phone="{{settings.contactPhone}}"
  show-consult="{{settings.wechatServiceEnabled}}"
  consult-label="咨询行程"
  phone-label="电话沟通"
/>
