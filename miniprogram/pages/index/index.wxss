/* pages/index/index.wxss */

page {
  background: #F2F4F7;
  margin: 0;
  padding: 0;
  overflow-x: hidden;
}

.page {
  min-height: 100vh;
  padding-bottom: 176rpx;
  box-sizing: border-box;
  margin: 0;
  width: 100%;
  overflow-x: hidden;
}

/* ===== Banner ===== */
.banner {
  position: relative;
  width: 100%;
  overflow: hidden;
  /* 兜底渐变：暖色晚霞山景 */
  background:
    radial-gradient(ellipse at 70% 35%, rgba(210, 140, 80, 0.5) 0%, transparent 50%),
    linear-gradient(175deg, #6B5A7A 0%, #8B6A5C 35%, #C08A60 65%, #3D4A2E 100%);
}

.banner-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.6s ease;
}

.banner-img-loaded {
  opacity: 1;
}

.banner-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.06) 0%,
    rgba(0, 0, 0, 0.0) 30%,
    rgba(0, 0, 0, 0.45) 100%
  );
}

/* banner 内部布局容器 */
.banner-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

/* 主标题区 */
.banner-main {
  padding: 24rpx 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.banner-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 3rpx;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.35);
  line-height: 1.25;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.90);
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.2);
}

/* 标签徽章组 */
.banner-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 10rpx;
}

.banner-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.20);
  border: 1rpx solid rgba(255, 255, 255, 0.30);
  border-radius: 100rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.94);
}

.badge-icon {
  font-size: 22rpx;
}

.badge-icon-check {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  background: #3B8BF2;
  border-radius: 50%;
  font-size: 18rpx;
  color: #fff;
}

/* ===== 内容区 ===== */
.content-sheet {
  background: #F2F4F7;
  position: relative;
  z-index: 2;
  overflow: hidden;
  padding-bottom: 24rpx;
}

/* ===== 核心入口区（横向滑动） ===== */
.entry-scroll-wrap {
  position: relative;
  margin-top: 24rpx;
}

.entry-scroll {
  white-space: nowrap;
}

.entry-track {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

/* 右侧渐变遮罩，暗示可滑动 */
.entry-scroll-fade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 60rpx;
  background: linear-gradient(to right, transparent, #F2F4F7);
  pointer-events: none;
}


.entry-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 100rpx;
  padding: 16rpx 24rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease;
}

.entry-chip:active {
  transform: scale(0.96);
}

.entry-chip-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.entry-chip-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  white-space: nowrap;
}

.entry-chip-arrow {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 2rpx;
}

/* ===== 导游区块 ===== */
.section-header {
  padding: 32rpx 24rpx 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.guide-section {
  margin: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* ===== 导游列表 ===== */
.list-wrap {
  padding: 0;
}

.card-wrap {
  margin-bottom: 18rpx;
}

.card-wrap:last-child {
  margin-bottom: 0;
}

/* ===== 骨架屏 ===== */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-card {
  background: #fff;
  padding: 28rpx 24rpx;
  display: flex;
  gap: 22rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sk-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #E8EAED;
  flex-shrink: 0;
  animation: pulse 1.4s ease infinite;
}

.sk-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
}

.sk-line {
  height: 24rpx;
  border-radius: 4rpx;
  background: #E8EAED;
  animation: pulse 1.4s ease infinite;
}

.sk-short { width: 40%; }
.sk-mid   { width: 65%; }
.sk-long  { width: 85%; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.45; }
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.empty-icon  { font-size: 80rpx; }
.empty-text  { font-size: 28rpx; color: #999; }

/* ===== 底部协议链接 ===== */
.footer-links {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 0 24rpx;
}

.footer-link {
  font-size: 22rpx;
  color: #A3AAB5;
}

.footer-divider {
  font-size: 22rpx;
  color: #D0D3D8;
}
