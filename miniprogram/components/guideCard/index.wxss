/* components/guideCard/index.wxss */

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.1s;
}

.card:active { transform: scale(0.984); }

/* ── 头像 ── */
.avatar-wrap { flex-shrink: 0; }

.avatar {
  width: 140rpx;
  height: 100%;
  min-height: 140rpx;
  border-radius: 16rpx;
  display: block;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.avatar-loaded {
  opacity: 1;
}

.avatar-fallback {
  width: 140rpx;
  height: 100%;
  min-height: 140rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-char { font-size: 48rpx; color: #fff; font-weight: 700; }

/* ── 信息区 ── */
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 1rpx;
}

.row-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stat-exp {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.stat-sep {
  font-size: 22rpx;
  color: #DDD;
}

.stat-thumb { font-size: 22rpx; }

.stat-service {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-pill {
  font-size: 22rpx;
  color: #2E86C1;
  background: #EBF5FB;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  line-height: 1.3;
}

/* ── 右箭头 ── */
.arrow {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding-left: 8rpx;
}

